# =============================================================
# Smart Infrastructure Monitoring Platform - Environment Config
# Copy this to .env and fill in real values
# NEVER commit .env to git
# =============================================================

# ── Hostname label shown in alerts and metrics ─────────────────
HOSTNAME_LABEL=my-server

# ── n8n Webhook (primary alert routing) ───────────────────────
N8N_WEBHOOK_URL=http://n8n:5678/webhook/monitor-alert

# ── Telegram (configured inside n8n, not used directly here) ──
# BOT_TOKEN=your_telegram_bot_token
# CHAT_ID=your_telegram_chat_id

# ── Discord (configured inside n8n) ───────────────────────────
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXX/XXX

# ── Email (configured inside n8n) ─────────────────────────────
# EMAIL_TO=your@email.com

# ── Grafana admin password ─────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=changeme123

# ── Prometheus retention ───────────────────────────────────────
PROMETHEUS_RETENTION=15d
